<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/CSS/style.css" />
    <link rel="stylesheet" href="/CSS/style-dashboard.css" />
    <title>Davalarım</title>
  </head>
  <body>
    <div class="navbar">
      <div class="nav-left">
        <a href="/member/dashboard">Altınbaş Avukat Bürosu — Davalarım</a>
      </div>
      <div class="nav-right">
        <form action="/logout" method="POST" class="inline-form">
          <button type="submit" class="link-button">Çıkış Yap</button>
        </form>
      </div>
    </div>

    <main class="dashboard-container">
      <% if (typeof error !== "undefined" && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="dashboard-section">
        <h2>Davalarım</h2>

        <% if (cases.length === 0) { %>
          <p class="empty-state">Şu an kayıtlı bir davanız bulunmuyor.</p>
        <% } else { %>
          <table class="cases-table">
            <thead>
              <tr>
                <th>Dosya No</th>
                <th>Konu</th>
                <th>Kayıt Tarihi</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% cases.forEach(function(caseItem) { %>
                <tr class="clickable-row" onclick="window.location='/member/cases/<%= caseItem._id %>'">
                  <td><%= caseItem.FileNumber %></td>
                  <td><%= caseItem.Subject %></td>
                  <td><%= new Date(caseItem.CreatedAt).toLocaleDateString('tr-TR') %></td>
                  <td>
                    <a href="/member/cases/<%= caseItem._id %>" class="btn btn-small">Detay</a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </section>

      <!-- ============ RANDEVU TALEPLERİM ============ -->
      <section class="dashboard-section">
        <h2>Randevu İste</h2>

        <% if (typeof error !== "undefined" && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form action="/member/appointments" method="POST" class="dashboard-form" id="appointmentForm">
          <div class="form-row">
            <div class="form-group">
              <label for="date">Gün Seçin</label>
              <select id="date" name="date" required>
                <option value="" disabled selected>Bir gün seçin</option>
                <% upcomingDates.forEach(function(d) { %>
                  <option value="<%= d.value %>"><%= d.label %></option>
                <% }); %>
              </select>
            </div>

            <div class="form-group">
              <label for="time">Saat Seçin</label>
              <select id="time" name="time" required disabled>
                <option value="" selected>Önce bir gün seçin</option>
              </select>
            </div>

            <div class="form-group" style="flex: 2;">
              <label for="note">Not (opsiyonel)</label>
              <input type="text" id="note" name="note" placeholder="Görüşmek istediğiniz konu hakkında kısa bir not" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary">Randevu Talep Et</button>
        </form>
      </section>
    </main>
      <script>
        document.getElementById("date").addEventListener("change", async function () {
          const selectedDate = this.value;
          const timeSelect = document.getElementById("time");

          timeSelect.disabled = true;
          timeSelect.innerHTML = '<option value="">Yükleniyor...</option>';

          try {
            const res = await fetch(`/member/available-times?date=${selectedDate}`);
            const data = await res.json();

            if (!data.times || data.times.length === 0) {
              timeSelect.innerHTML = '<option value="">Bu gün için uygun saat yok</option>';
              return;
            }

            timeSelect.innerHTML = '<option value="" disabled selected>Bir saat seçin</option>';
            data.times.forEach(function (time) {
              const option = document.createElement("option");
              option.value = time;
              option.textContent = time;
              timeSelect.appendChild(option);
            });

            timeSelect.disabled = false;
          } catch (err) {
            console.error(err);
            timeSelect.innerHTML = '<option value="">Saatler yüklenemedi</option>';
          }
        });
      </script>
  </body>
</html>