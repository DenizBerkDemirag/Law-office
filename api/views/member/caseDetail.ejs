<!doctype html>
<html lang="tr" data-i18n-title="page_title_member_case">

<head>
    <link rel="icon" type="image/svg+xml" href="/Fotograflar/altinbas-logo.svg" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/CSS/style.css" />
    <link rel="stylesheet" href="/CSS/style-dashboard.css" />
    <link rel="stylesheet" href="/CSS/lang-selector.css" />
    <title>Dava Detayı — <%= caseItem.FileNumber %>| Altınbaş Avukatlık Bürosu</title>
</head>

<body>
    <header class="navbar">
        <div class="nav-left"> <a href="/member/dashboard" class="brand-title"> <img
                    src="/Fotograflar/altinbas-logo.svg" alt="Altınbaş Avukatlık Bürosu"
                    style="height: 36px; filter: brightness(0) invert(1);" /> <span data-i18n="dash_back_panel">←
                    Davalarıma Dön</span> </a> </div>
        <div class="nav-right">
            <div class="lang-selector"> <button type="button" class="lang-btn" id="langDropdownBtn"
                    style="color: #FFFFFF; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                    <span class="lang-flag" id="currentLangFlag">🇹🇷</span> <span class="lang-code"
                        id="currentLangCode">TR</span> <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6" />
                    </svg> </button>
                <div class="lang-menu" id="langMenu"> <button type="button"
                        onclick="setLanguage('tr')"><span>🇹🇷</span>Türkçe</button> <button type="button"
                        onclick="setLanguage('en')"><span>🇬🇧</span>English</button> <button type="button"
                        onclick="setLanguage('de')"><span>🇩🇪</span>Deutsch</button> <button type="button"
                        onclick="setLanguage('fr')"><span>🇫🇷</span>Français</button> <button type="button"
                        onclick="setLanguage('es')"><span>🇪🇸</span>Español</button> <button type="button"
                        onclick="setLanguage('it')"><span>🇮🇹</span>Italiano</button> <button type="button"
                        onclick="setLanguage('ru')"><span>🇷🇺</span>Русский</button> <button type="button"
                        onclick="setLanguage('ar')"><span>🇸🇦</span>العربية</button> </div>
            </div>
        </div>
    </header>
    <main class="dashboard-container">
        <section class="dashboard-section">
            <h2 data-i18n="member_case_detail_title">Dava Detay Bilgileri</h2>
            <dl class="case-info">
                <dt data-i18n="dash_case_no">Dosya No (Esas No)</dt>
                <dd><strong>
                        <%= caseItem.FileNumber %>
                    </strong></dd>
                <dt data-i18n="dash_case_subject">Dava Konusu</dt>
                <dd>
                    <%= caseItem.Subject %>
                </dd>
                <dt data-i18n="member_date">Sisteme Kayıt Tarihi</dt>
                <dd><span data-i18n-date="<%= caseItem.CreatedAt %>">
                        <%= new Date(caseItem.CreatedAt).toLocaleDateString('tr-TR') %>
                    </span></dd>
            </dl>
        </section>
        <section class="dashboard-section">
            <h2 data-i18n="member_case_docs_title">Dava Dosyasındaki Belgeler</h2>
            <% if (documents.length===0) { %>
                <p class="empty-state" data-i18n="empty_docs_member">Bu davaya ait tarafınıza sunulmuş henüz bir belge
                    bulunmuyor.</p>
                <% } else { %>
                    <ul class="document-list">
                        <% documents.forEach(function(document) { %>
                            <li> <a href="/member/documents/<%= document._id %>/download" target="_blank">
                                    <%= document.FileName %>
                                </a> <span class="document-date"><span data-i18n="label_upload_date">Yüklenme:</span>
                                    <span data-i18n-date="<%= document.UploadedAt %>">
                                        <%= new Date(document.UploadedAt).toLocaleDateString('tr-TR') %>
                                    </span></span> </li>
                            <% }); %>
                    </ul>
                    <% } %>
        </section>
    </main> <%- include('../partials/chat-bar') %>
        <script src="/JS/i18n.js"></script>
</body>

</html>