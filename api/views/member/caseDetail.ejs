<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/CSS/style.css" />
    <link rel="stylesheet" href="/CSS/style-dashboard.css" />
    <title>Dava Detayı — <%= dava.dosyaNo %></title>
  </head>
  <body>
    <div class="navbar">
      <div class="nav-left">
        <a href="/member/dashboard">← Davalarıma Dön</a>
      </div>
    </div>

    <main class="dashboard-container">
      <section class="dashboard-section">
        <h2>Dava Bilgileri</h2>
        <dl class="case-info">
          <dt>Dosya No</dt>
          <dd><%= dava.dosyaNo %></dd>

          <dt>Konu</dt>
          <dd><%= dava.Konu %></dd>

          <dt>Kayıt Tarihi</dt>
          <dd><%= new Date(dava.created_at).toLocaleDateString('tr-TR') %></dd>
        </dl>
      </section>

      <section class="dashboard-section">
        <h2>Belgeler</h2>

        <% if (belgeler.length === 0) { %>
          <p class="empty-state">Bu davaya ait belge bulunmuyor.</p>
        <% } else { %>
          <ul class="document-list">
            <% belgeler.forEach(function(belge) { %>
              <li>
                <span><%= belge.FileName %></span>
                <span class="document-date"><%= new Date(belge.UploadedAt).toLocaleDateString('tr-TR') %></span>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </section>
    </main>
  </body>
</html>