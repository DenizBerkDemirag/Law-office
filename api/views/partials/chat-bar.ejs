<% if (typeof session !== "undefined" && session && session.userId) { %>
  <!-- Messaging Bar CSS & JS -->
  <link rel="stylesheet" href="/CSS/chat-bar.css" />

  <div class="chat-bar-wrapper" id="chatBarWrapper">
    <!-- Trigger Bar Header -->
    <div class="chat-bar-header" id="chatBarHeader">
      <div class="chat-bar-header-info">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        <span data-i18n="msg_bar_title">Mesajlar</span>
        <span class="chat-unread-badge hidden" id="chatUnreadBadge">0</span>
      </div>
      <button type="button" class="chat-bar-toggle-btn" id="chatBarToggleBtn" aria-label="Mesajlaşma Barını Aç/Kapat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 15l-6-6-6 6"></path>
        </svg>
      </button>
    </div>

    <!-- Expanded Body Window -->
    <div class="chat-bar-body" id="chatBarBody">
      <div class="chat-views">
        <!-- 1. Contacts View -->
        <div class="chat-view-contacts" id="chatViewContacts">
          <div class="chat-search-box">
            <input type="text" class="chat-search-input" id="chatSearchInput" placeholder="Kişilerde ara..." data-i18n-placeholder="msg_search_placeholder" />
          </div>
          <div class="chat-contacts-list" id="chatContactsList">
            <div class="chat-empty-msg" data-i18n="msg_loading">Kişiler yükleniyor...</div>
          </div>
        </div>

        <!-- 2. Chat View -->
        <div class="chat-view-messages" id="chatViewMessages">
          <div class="chat-convo-header">
            <button type="button" class="chat-back-btn" id="chatBackBtn" title="Geri">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"></path>
              </svg>
            </button>
            <div class="chat-contact-avatar" style="width: 34px; height: 34px; margin-right: 8px;">
              <img id="chatConvoUserAvatar" src="/Fotograflar/altinbas-logo.svg" alt="User" />
            </div>
            <div class="chat-convo-user-info">
              <div class="chat-convo-user-name" id="chatConvoUserName">Kullanıcı</div>
              <div class="chat-convo-user-role" id="chatConvoUserRole">Rol</div>
            </div>
          </div>

          <div class="chat-messages-area" id="chatMessagesArea">
            <div class="chat-empty-msg" data-i18n="msg_select_contact">Sohbet seçin.</div>
          </div>

          <form class="chat-input-area" id="chatInputForm" onsubmit="return false;">
            <input type="text" class="chat-input-text" id="chatMessageInput" placeholder="Mesajınızı yazın..." data-i18n-placeholder="msg_type_placeholder" autocomplete="off" />
            <button type="submit" class="chat-send-btn" id="chatSendBtn" aria-label="Gönder">
              <svg width="16" height="16" viewBox="0 0 24 24">
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="/JS/chat-bar.js"></script>
<% } %>
