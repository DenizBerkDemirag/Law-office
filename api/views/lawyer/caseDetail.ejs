<!doctype html>
<html lang="tr" data-i18n-title="page_title_case_detail"> <head>
    <link rel="icon" type="image/svg+xml" href="/Fotograflar/altinbas-logo.svg" /> <meta charset="UTF-8" /> <meta name="viewport" content="width=device-width, initial-scale=1.0" /> <link rel="stylesheet" href="/CSS/style.css" /> <link rel="stylesheet" href="/CSS/style-dashboard.css" /> <link rel="stylesheet" href="/CSS/lang-selector.css" /> <title>Dava Detayı — <%= caseItem.FileNumber %>| Altınbaş Avukatlık Bürosu</title> </head> <body> <header class="navbar"> <div class="nav-left"> <a href="/lawyer/dashboard" class="brand-title"> <img src="/Fotograflar/altinbas-logo.svg" alt="Altınbaş Avukatlık Bürosu" style="height: 36px; filter: brightness(0) invert(1);" /> <span data-i18n="dash_back_panel">← Panele Dön</span> </a> </div> <div class="nav-right"> <div class="lang-selector"> <button type="button" class="lang-btn" id="langDropdownBtn" style="color: #FFFFFF; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);"> <span class="lang-flag" id="currentLangFlag">🇹🇷</span> <span class="lang-code" id="currentLangCode">TR</span> <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg> </button> <div class="lang-menu" id="langMenu"> <button type="button" onclick="setLanguage('tr')"><span>🇹🇷</span>Türkçe</button> <button type="button" onclick="setLanguage('en')"><span>🇬🇧</span>English</button> <button type="button" onclick="setLanguage('de')"><span>🇩🇪</span>Deutsch</button> <button type="button" onclick="setLanguage('fr')"><span>🇫🇷</span>Français</button> <button type="button" onclick="setLanguage('es')"><span>🇪🇸</span>Español</button> <button type="button" onclick="setLanguage('it')"><span>🇮🇹</span>Italiano</button> <button type="button" onclick="setLanguage('ru')"><span>🇷🇺</span>Русский</button> <button type="button" onclick="setLanguage('ar')"><span>🇸🇦</span>العربية</button> </div> </div> </div> </header> <main class="dashboard-container"> <% if (typeof error !== "undefined" && error) { %> <div class="alert alert-error"><%= error %></div> <% } %> <section class="dashboard-section"> <h2 data-i18n="case_info_title">Dava Künye Bilgileri</h2> <dl class="case-info"> <dt data-i18n="dash_case_no">Dosya No (Esas No)</dt> <dd><strong><%= caseItem.FileNumber %></strong></dd> <dt data-i18n="dash_case_subject">Dava Konusu</dt> <dd><%= caseItem.Subject %></dd> <dt data-i18n="dash_case_member">Müvekkil</dt> <dd><%= caseItem.Member ? (caseItem.Member.Username || caseItem.Member.Email) : "—" %></dd> <dt data-i18n="member_date">Sisteme Kayıt Tarihi</dt> <dd><span data-i18n-date="<%= caseItem.CreatedAt %>"><%= new Date(caseItem.CreatedAt).toLocaleDateString('tr-TR') %></span></dd> </dl> </section> <section class="dashboard-section"> <h2 data-i18n="case_documents_title">Dava Belgeleri ve Ekler</h2> <% if (documents.length === 0) { %> <p class="empty-state" data-i18n="empty_docs_lawyer">Bu davaya ait kayıtlı herhangi bir belge bulunmuyor.</p> <% } else { %> <ul class="document-list"> <% documents.forEach(function(document) { %> <li> <a href="/lawyer/documents/<%= document._id %>/download" target="_blank"> <%= document.FileName %> </a> <span class="document-date"><span data-i18n="label_upload_date">Yüklenme:</span> <span data-i18n-date="<%= document.UploadedAt %>"><%= new Date(document.UploadedAt).toLocaleDateString('tr-TR') %></span></span> </li> <% }); %> </ul> <% } %> <div style="background: #F8FAFC; padding: 24px; border-radius: 12px; border: 1.5px dashed var(--border); margin-top: 20px;"> <h3 style="font-size: 16px; margin-bottom: 12px; font-family: 'Plus Jakarta Sans', sans-serif;" data-i18n="upload_new_doc">Yeni Belge Yükle</h3> <form action="/lawyer/cases/<%= caseItem._id %>/documents" method="POST" enctype="multipart/form-data" class="dashboard-form" id="documentUploadForm"> <div class="form-group" style="margin-bottom: 16px;"> <label for="file" data-i18n="file_select_label">Dosya Seçin (Desteklenen formatlar: JPEG, PNG, WEBP, PDF)</label> <input type="file" id="file" name="file" accept=".jpg,.jpeg,.png,.webp,.pdf" required /> </div> <button type="submit" id="uploadBtn" class="btn btn-primary" data-i18n="upload_btn">Belgeyi Dosyaya Ekle</button> </form> </div> </section> </main> <script>document.addEventListener("DOMContentLoaded", function () { const uploadForm = document.getElementById("documentUploadForm"); if (uploadForm) { uploadForm.addEventListener("submit", function () { const btn = document.getElementById("uploadBtn"); if (btn) { btn.disabled = true; btn.textContent = t("btn_uploading"); } }); } }); </script> <script src="/JS/i18n.js"></script> </body>
</html>