<!doctype html>
<html lang="tr" data-i18n-title="page_title_case_edit">

<head>
    <link rel="icon" type="image/svg+xml" href="/Fotograflar/altinbas-logo.svg" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/CSS/style.css" />
    <link rel="stylesheet" href="/CSS/style-dashboard.css" />
    <link rel="stylesheet" href="/CSS/lang-selector.css" />
    <title>Davayı Düzenle — <%= caseItem.FileNumber %>| Altınbaş Avukatlık Bürosu</title>
</head>

<body>
    <header class="navbar">
        <div class="nav-left"> <a href="/lawyer/manage" class="brand-title"> <img src="/Fotograflar/altinbas-logo.svg"
                    alt="Altınbaş Avukatlık Bürosu" style="height: 36px; filter: brightness(0) invert(1);" /> <span
                    data-i18n="dash_back_panel">← Yönetime Dön</span> </a> </div>
        <div class="nav-right">
            <div class="lang-selector"> <button type="button" class="lang-btn" id="langDropdownBtn"
                    style="color: #FFFFFF; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                    <span class="lang-flag" id="currentLangFlag">🇹🇷</span> <span class="lang-code"
                        id="currentLangCode">TR</span> <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6" />
                    </svg> </button>
                <div class="lang-menu" id="langMenu"> <button type="button"
                        onclick="setLanguage('tr')"><span>🇹🇷</span>Türkçe</button> <button type="button"
                        onclick="setLanguage('en')"><span>🇬🇧</span>English</button> <button type="button"
                        onclick="setLanguage('de')"><span>🇩🇪</span>Deutsch</button> <button type="button"
                        onclick="setLanguage('fr')"><span>🇫🇷</span>Français</button> <button type="button"
                        onclick="setLanguage('es')"><span>🇪🇸</span>Español</button> <button type="button"
                        onclick="setLanguage('it')"><span>🇮🇹</span>Italiano</button> <button type="button"
                        onclick="setLanguage('ru')"><span>🇷🇺</span>Русский</button> <button type="button"
                        onclick="setLanguage('ar')"><span>🇸🇦</span>العربية</button> </div>
            </div>
        </div>
    </header>
    <main class="dashboard-container">
        <section class="dashboard-section">
            <h2 data-i18n="case_update_title">️ Dava Bilgilerini Güncelle</h2>
            <form action="/lawyer/cases/<%= caseItem._id %>/update" method="POST" class="dashboard-form">
                <div class="form-row">
                    <div class="form-group"> <label for="memberId" data-i18n="dash_case_member">Müvekkil</label> <select
                            id="memberId" name="memberId" required>
                            <% members.forEach(function(member) { %>
                                <option value="<%= member._id %>" <%=(caseItem.Member &&
                                    caseItem.Member._id.toString()===member._id.toString()) ? "selected" : "" %>> <%=
                                        member.Username || member.Email %>
                                </option>
                                <% }); %>
                        </select> </div>
                    <div class="form-group"> <label for="fileNumber" data-i18n="dash_case_no">Dosya No (Esas No)</label>
                        <input type="text" id="fileNumber" name="fileNumber" value="<%= caseItem.FileNumber %>"
                            required />
                    </div>
                    <div class="form-group"> <label for="subject" data-i18n="dash_case_subject">Dava Konusu</label>
                        <input type="text" id="subject" name="subject" value="<%= caseItem.Subject %>" required />
                    </div>
                </div> <button type="submit" class="btn btn-primary" data-i18n="dash_update">Değişiklikleri
                    Kaydet</button>
            </form>
        </section>
    </main> <%- include('../partials/chat-bar') %>
        <script src="/JS/i18n.js"></script>
</body>

</html>