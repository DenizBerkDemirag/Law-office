<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/CSS/style.css" />
    <link rel="stylesheet" href="/CSS/style-dashboard.css" />
    <title>Belge Arşivi</title>
  </head>
  <body>
    <div class="navbar">
      <div class="nav-left">
        <a href="/lawyer/manage">← Yönetime Dön</a>
      </div>
    </div>

    <main class="dashboard-container">
      <section class="dashboard-section">
        <h2>Belge Arşivi</h2>
        <p class="empty-state" style="font-style: normal; margin-bottom: 20px;">
          Silinmiş davalara ait belgeler burada saklanır ve indirilebilir.
        </p>

        <% if (archivedDocuments.length === 0) { %>
          <p class="empty-state">Arşivde belge bulunmuyor.</p>
        <% } else { %>
          <table class="cases-table">
            <thead>
              <tr>
                <th>Belge</th>
                <th>Eski Dosya No</th>
                <th>Eski Konu</th>
                <th>Müvekkil Email</th>
                <th>Arşiv Tarihi</th>
              </tr>
            </thead>
            <tbody>
              <% archivedDocuments.forEach(function(document) { %>
                <tr>
                  <td><a href="/lawyer/documents/<%= document._id %>/download" target="_blank"><%= document.FileName %></a></td>
                  <td><%= document.ArchivedCaseFileNumber || "—" %></td>
                  <td><%= document.ArchivedCaseSubject || "—" %></td>
                  <td><%= document.ArchivedMemberEmail || "—" %></td>
                  <td><%= new Date(document.ArchivedAt).toLocaleDateString('tr-TR') %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </section>
    </main>
  </body>
</html>