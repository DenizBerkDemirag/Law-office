<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/CSS/style.css" />
    <link rel="stylesheet" href="/CSS/style-dashboard.css" />
    <title>Büro Yönetim Paneli</title>
  </head>
  <body>
    <div class="navbar">
      <div class="nav-left">
        <a href="/lawyer/dashboard">Altınbaş Avukat Bürosu — Yönetim Paneli</a>
      </div>
      <div class="nav-right">
        <a href="/lawyer/manage" class="btn btn-primary">Kayıt</a>
        <form action="/logout" method="POST" class="inline-form">
          <button type="submit" class="link-button">Çıkış Yap</button>
        </form>
      </div>
    </div>

    <main class="dashboard-container">
      <section class="dashboard-section">
        <h2>Tüm Davalar</h2>

        <!-- ============ FİLTRE FORMU ============ -->
        <form action="/lawyer/dashboard" method="GET" class="dashboard-form" style="margin-bottom: 20px;">
          <div class="form-row">
            <div class="form-group">
              <label for="memberId">Müvekkile Göre Filtrele</label>
              <select id="memberId" name="memberId">
                <option value="">Tüm Müvekkiller</option>
                <% members.forEach(function(member) { %>
                  <option value="<%= member._id %>" <%= selectedMemberId === member._id.toString() ? "selected" : "" %>>
                    <%= member.Username || member.Email %>
                  </option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label for="date">Tarihe Göre Filtrele</label>
              <input type="date" id="date" name="date" value="<%= selectedDate %>" />
            </div>
            <div class="form-group" style="justify-content: flex-end;">
              <button type="submit" class="btn btn-primary">Filtrele</button>
              <% if (selectedMemberId || selectedDate) { %>
                <a href="/lawyer/dashboard" class="btn btn-small" style="margin-left: 8px;">Temizle</a>
              <% } %>
            </div>
          </div>
        </form>

        <% if (cases.length === 0) { %>
          <p class="empty-state">
            <% if (selectedMemberId || selectedDate) { %>
              Filtreye uygun dava bulunamadı.
            <% } else { %>
              Henüz kayıtlı dava bulunmuyor.
            <% } %>
          </p>
        <% } else { %>
          <% if (sortBy) { %>
            <div style="margin-bottom: 10px;">
              <a href="<%= clearSortUrl %>" class="btn btn-small">Sıralamayı Kaldır</a>
            </div>
          <% } %>
          <table class="cases-table">
            <thead>
              <tr>
                <th>Dosya No</th>
                <th>Konu</th>
                <th>
                  <a href="<%= memberSortUrl %>" class="sortable-header">
                    Müvekkil<% if (sortBy === "member") { %> <%= sortOrder === "desc" ? "▼" : "▲" %><% } %>
                  </a>
                </th>
                <th>
                  <a href="<%= dateSortUrl %>" class="sortable-header">
                    Kayıt Tarihi<% if (sortBy === "date") { %> <%= sortOrder === "desc" ? "▼" : "▲" %><% } %>
                  </a>
                </th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% cases.forEach(function(caseItem) { %>
                <tr>
                  <td><%= caseItem.FileNumber %></td>
                  <td><%= caseItem.Subject %></td>
                  <td><%= caseItem.Member ? (caseItem.Member.Username || caseItem.Member.Email) : "—" %></td>
                  <td><%= new Date(caseItem.CreatedAt).toLocaleDateString('tr-TR') %></td>
                  <td>
                    <a href="/lawyer/cases/<%= caseItem._id %>" class="btn btn-small">Detay</a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </section>
    </main>
  </body>
</html>