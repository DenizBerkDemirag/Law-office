  <!-- SMOOTH SCROLL SCRIPT -->
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      function getTargetPosition(hash) {
        if (!hash || hash === "#") return null;
        const target = document.querySelector(hash);
        if (target) {
          const navbarHeight = document.querySelector(".navbar")?.offsetHeight || 80;
          return target.getBoundingClientRect().top + window.pageYOffset - navbarHeight - 15;
        }
        return null;
      }

      function scrollToHash(hash) {
        const pos = getTargetPosition(hash);
        if (pos !== null) {
          window.scrollTo({
            top: Math.max(0, pos),
            behavior: "smooth"
          });
        }
      }

      // Intercept anchor link clicks
      document.querySelectorAll('a[href*="#"]').forEach(function (anchor) {
        anchor.addEventListener("click", function (e) {
          const href = this.getAttribute("href");
          if (!href) return;

          const parts = href.split("#");
          const path = parts[0];
          const hash = parts[1] ? "#" + parts[1] : "";

          // Same-page smooth scroll
          if (path === "" || path === "/" || path === window.location.pathname) {
            if (hash) {
              e.preventDefault();
              scrollToHash(hash);
              history.pushState(null, null, hash);
            }
          }
        });
      });

      // Handle page load with hash (e.g. from /ekip/ahmet-altinbas#hizmetler)
      if (window.location.hash) {
        setTimeout(function () {
          scrollToHash(window.location.hash);
        }, 250);
      }
    });
  </script>

